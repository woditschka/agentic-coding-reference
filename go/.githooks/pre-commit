#!/bin/sh
# Pre-commit hook: format and vet Go code before committing.
# Install: make hooks

set -e

# Check if there are staged Go files
STAGED_GO=$(git diff --cached --name-only --diff-filter=ACM -- '*.go' || true)
if [ -z "$STAGED_GO" ]; then
    exit 0
fi

echo "pre-commit: running go fmt..."
UNFMT=$(gofmt -l $STAGED_GO)
if [ -n "$UNFMT" ]; then
    echo "pre-commit: these files need formatting:"
    echo "$UNFMT"
    echo "Run: go fmt ./..."
    exit 1
fi

echo "pre-commit: running go vet..."
go vet ./...

echo "pre-commit: passed"
